# mt configuration — copy to the right location for your platform and customise.
#
#   macOS:  ~/Library/Application Support/mt/config.yaml
#   Linux:  ~/.config/mt/config.yaml
#   Local:  ./mt.yaml  (overrides the above)
#
# ─── Quick-start: apps shorthand ──────────────────────────────────────────────
# List Mac app names under apps: and mt generates the open -a command for you.
# No cmd/status/launch_msg needed — just the name as macOS knows it.
#
#   domains:
#     - name: "My Apps"
#       apps:
#         - "Microsoft Outlook"
#         - "Microsoft Edge"
#         - "Visual Studio Code"
#         - "Slack"
#
# ─── Multi-workspace config ────────────────────────────────────────────────────
# Use workspaces: to group different sets of domains and switch between them
# with Tab / Shift+Tab inside mt.
#
# ──────────────────────────────────────────────────────────────────────────────
#
# Full field reference:
#   name       — display label (required)
#   status     — hint text shown in the right pane before any command runs
#   cmd        — command and arguments to execute on Enter (omit to disable)
#   launch_msg — message shown when cmd exits 0 with no output (e.g. open -a)
#   sequence   — ordered list of target names to run in series (stops on failure)
#   host       — SSH host ([user@]hostname); cmd is run as: ssh host <cmd>
#   include    — (top-level) list of YAML files to merge; must be within $HOME
#
# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# Press [/] in mt to open the AI prompt bar. Type a natural-language request and
# press Enter. The LLM will route it to an existing target, generate a new
# command (e.g. an osascript to create a meeting), or answer your question.
#
# ── Apple Foundation Models (on-device, private, no API key — macOS 26+) ──────
# Requires Apple Intelligence enabled. Build the bridge binary once:
#   make apple-bridge            # produces ./mt-apple-bridge
#   cp mt-apple-bridge $(dirname $(which mt))/   # place alongside the mt binary
#
# llm:
#   provider: apple
#   # bridge_path: /usr/local/bin/mt-apple-bridge   # optional; searched in PATH by default
#
# ── llama.cpp — Metal-accelerated local inference (Apple Silicon) ──────────────
# Runs entirely on-device using the Metal GPU; works with any GGUF model.
#   brew install llama.cpp
#
# M5 Max (36 GB unified memory) recommended settings:
#   llama-server -m ~/models/mistral-7b-instruct.Q4_K_M.gguf \
#                --n-gpu-layers 99 \
#                --ctx-size 8192 \
#                --threads 10 \
#                --port 8080
#
#   --n-gpu-layers 99  offloads all transformer layers to Metal GPU
#   --ctx-size 8192    36 GB fits large contexts; raise to 16384 for bigger models
#   --threads 10       matches M5 Max's 10 performance cores
#
# Model size guide for 36 GB unified memory:
#   Q4_K_M quantisation: fits 70B models on-device
#   Q8_0   quantisation: fits up to ~34B models
#   F16                : fits up to ~17B models
#
# llm:
#   provider: llamacpp
#   model: mistral-7b-instruct   # informational label; server uses the loaded model
#   # base_url: http://localhost:8080   # default
#
# ── OpenAI or any OpenAI-compatible cloud provider ─────────────────────────────
#
# llm:
#   provider: openai
#   model: gpt-4o-mini           # or gpt-4o, o1-mini, etc.
#   base_url: https://api.openai.com   # override for vLLM, LMStudio, etc.
#   api_key: sk-...              # or set OPENAI_API_KEY env var
#
# ── LiteLLM proxy (routes to many providers) ───────────────────────────────────
#   pip install litellm
#   litellm --model <provider>/<model>
#
# llm:
#   provider: litellm            # default when provider is omitted
#   model: llama3.1:8b
#   base_url: http://localhost:4000   # default

# ── Example: multi-workspace config with per-app actions ──────────────────────

workspaces:

  # ── Microsoft workspace ─────────────────────────────────────────────────────
  - name: "Microsoft"
    domains:

      - name: "Outlook"
        targets:
          - name: "Open Outlook"
            cmd: ["open", "-a", "Microsoft Outlook"]
            launch_msg: "Opening Outlook…"

          - name: "New Email"
            status: "Opens a new draft email in Outlook"
            cmd: ["open", "ms-outlook://compose"]
            launch_msg: "Opening new email…"

          - name: "Open Inbox"
            status: "Opens the Outlook inbox"
            cmd: ["open", "ms-outlook://mail"]
            launch_msg: "Opening inbox…"

          - name: "Open Calendar"
            status: "Opens the Outlook calendar view"
            cmd: ["open", "ms-outlook://calendar"]
            launch_msg: "Opening calendar…"

      - name: "Word"
        targets:
          - name: "Open Word"
            cmd: ["open", "-a", "Microsoft Word"]
            launch_msg: "Opening Word…"

          - name: "New Document"
            status: "Creates a blank Word document"
            cmd: ["osascript", "-e",
                  "tell application \"Microsoft Word\" to make new document"]
            launch_msg: "Creating new document…"

      - name: "Excel"
        targets:
          - name: "Open Excel"
            cmd: ["open", "-a", "Microsoft Excel"]
            launch_msg: "Opening Excel…"

          - name: "New Workbook"
            status: "Creates a blank Excel workbook"
            cmd: ["osascript", "-e",
                  "tell application \"Microsoft Excel\" to make new workbook"]
            launch_msg: "Creating new workbook…"

      - name: "Edge"
        targets:
          - name: "Open Edge"
            cmd: ["open", "-a", "Microsoft Edge"]
            launch_msg: "Opening Edge…"

          - name: "Outlook Web"
            status: "Opens Outlook in Edge"
            cmd: ["open", "-a", "Microsoft Edge", "--args",
                  "https://outlook.office.com"]
            launch_msg: "Opening Outlook Web…"

          - name: "New InPrivate Window"
            status: "Opens a private browsing window"
            cmd: ["open", "-a", "Microsoft Edge", "--args",
                  "--inprivate"]
            launch_msg: "Opening InPrivate window…"

  # ── Dev workspace ────────────────────────────────────────────────────────────
  - name: "Dev"
    domains:

      - name: "VS Code"
        targets:
          - name: "Open VS Code"
            cmd: ["open", "-a", "Visual Studio Code"]
            launch_msg: "Opening VS Code…"

          - name: "Open Current Dir"
            status: "Opens the current working directory in VS Code"
            cmd: ["code", "."]
            launch_msg: "Opening folder in VS Code…"

      - name: "Terminal"
        targets:
          - name: "New Terminal Window"
            cmd: ["open", "-a", "Terminal"]
            launch_msg: "Opening Terminal…"

          - name: "New iTerm2 Window"
            cmd: ["open", "-a", "iTerm"]
            launch_msg: "Opening iTerm2…"

      - name: "Infrastructure"
        targets:
          - name: "Docker Up"
            status: "Docker: Stopped\n\nPress [Enter] to start containers"
            cmd: ["docker", "compose", "up", "-d"]

          - name: "Docker Down"
            status: "Press [Enter] to stop all containers"
            cmd: ["docker", "compose", "down"]

          - name: "Postgres"
            status: "Container: postgres\nPress [Enter] to check status"
            cmd: ["docker", "ps", "--filter", "name=postgres", "--format",
                  "table {{.Names}}\t{{.Status}}\t{{.Ports}}"]

          - name: "Redis"
            status: "Container: redis\nPress [Enter] to check status"
            cmd: ["docker", "ps", "--filter", "name=redis", "--format",
                  "table {{.Names}}\t{{.Status}}\t{{.Ports}}"]

      - name: "Context/Git"
        targets:
          - name: "Git Status"
            status: "Press [Enter] to run git status"
            cmd: ["git", "status"]

          - name: "Git Diff"
            status: "Press [Enter] to view diff"
            cmd: ["git", "diff"]

          - name: "Branches"
            status: "Press [Enter] to list branches"
            cmd: ["git", "branch", "-a"]

          - name: "Stash"
            status: "Press [Enter] to list stash"
            cmd: ["git", "stash", "list"]

  # ── Deploy workspace (fill in your tooling) ──────────────────────────────────
  - name: "Deploy"
    domains:

      - name: "RunLayer"
        targets:
          # Sequence: runs Build → Test → Deploy Staging in order.
          # Any step that exits non-zero stops the sequence.
          - name: "Full Pipeline"
            sequence: ["Build", "Test", "Deploy Staging"]

          - name: "Build"
            status: "Press [Enter] to build"
            # cmd: ["make", "build"]

          - name: "Test"
            status: "Press [Enter] to run tests"
            # cmd: ["make", "test"]

          - name: "Deploy Staging"
            status: "Press [Enter] to deploy to staging"
            # cmd: ["./scripts/deploy.sh", "staging"]

          - name: "Deploy Production"
            status: "Press [Enter] to deploy to production"
            # cmd: ["./scripts/deploy.sh", "production"]

          # SSH target: cmd runs on the remote host via `ssh host <cmd>`
          # host must match [a-zA-Z0-9][a-zA-Z0-9._@%-]* (no leading dash)
          - name: "Tail Prod Logs"
            status: "Stream live application logs from production"
            # host: "deploy@prod.example.com"
            # cmd: ["journalctl", "-fu", "myapp"]

          - name: "View Logs"
            status: "Press [Enter] to stream logs"
            # cmd: ["./scripts/logs.sh", "--tail", "100"]

          - name: "Rollback"
            status: "Press [Enter] to rollback last deploy"
            # cmd: ["./scripts/rollback.sh"]

# ── Alternative: simple flat config (single workspace, apps shorthand) ─────────
#
# domains:
#   - name: "Apps"
#     apps:
#       - "Microsoft Outlook"
#       - "Microsoft Word"
#       - "Microsoft Excel"
#       - "Microsoft Edge"
#       - "Slack"
#       - "Zoom"
#
#   - name: "Dev Tools"
#     apps:
#       - "Visual Studio Code"
#       - "iTerm"
#     targets:
#       - name: "Git Status"
#         cmd: ["git", "status"]

# ── Include directive ──────────────────────────────────────────────────────────
# Split large configs into multiple files. Included paths must resolve within
# $HOME (symlinks are followed and checked). Relative paths resolve from the
# directory of the file that declares them. Circular includes are skipped.
#
# include:
#   - shared/team-tools.yaml          # relative to this file's directory
#   - ~/work/configs/shared.yaml      # absolute path within $HOME
#
# domains:
#   - name: "Local"
#     targets:
#       - name: "My Command"
#         cmd: ["echo", "hello"]
